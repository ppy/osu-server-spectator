{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [{
    "src": [{
      "files": ["osu.Server.Spectator.csproj"],
      "src": "../osu.Server.Spectator"
    }],
    "dest": "_metadata/referee-api/managed-references",
    "filter": "filter-config.yml",
    "disableDefaultFilter": true
  }],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "referee-hub-api.md",
          "toc.yml",
          "_metadata/referee-api/managed-references/*.yml"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "overwrite": [
      "_metadata/referee-api/overwrites/*.md"
    ],
    "resource": [
      {
        "files": [
          "logo.png",
          "_metadata/referee-api/schemas/*.json"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "osu-server-spectator",
      "_appTitle": "osu-server-spectator",
      "_appFaviconPath": "/images/favicon/favicon-32x32.png",
      "_appLogoPath": "logo.png",
      "_enableSearch": true,
      "_disableBreadcrumb": true,
      "_disableContribution": true,
      "pdf": false
    }
  }
}